            <zone h='3942' id='3' type-v2='title' w='98426' x='787' y='830' />
            <zone fixed-size='145' h='15041' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98426' x='787' y='4772' />
            <zone h='79357' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98426' x='787' y='19813'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Benchmarking Aiming Skills Across Ranks:&#10;The box plot displays the distribution of headshot percentages by player rank. Higher ranks demonstrate tighter and higher accuracy distributions. Selecting a rank highlights agent and map performance relevant to players at that competitive level.' captured-sheet='Sq3' id='1' />
                </story-points>
              </flipboard>
            </zone>
